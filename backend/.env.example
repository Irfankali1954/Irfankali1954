# --- Core ---
APP_ENV=development
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_TTL_MIN=60

# --- Database ---
DATABASE_URL=sqlite:///./epc.db
# DATABASE_URL=postgresql+psycopg://user:pw@localhost:5432/epc

# --- ERP connectors ---
ORACLE_ERP_BASE_URL=
ORACLE_ERP_CLIENT_ID=
ORACLE_ERP_CLIENT_SECRET=

SAP_S4_BASE_URL=
SAP_S4_CLIENT_ID=
SAP_S4_CLIENT_SECRET=

# --- EDC connectors (Procore / Aconex / Bluebeam) ---
PROCORE_BASE_URL=https://api.procore.com
PROCORE_TOKEN=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- First-boot admin bootstrap (demo only) ---
# Both must be set for the bootstrap to run on first boot. No-op on
# subsequent boots once the user exists. Production: leave unset and
# create users via /api/v1/admin/users once an initial admin exists.
BOOTSTRAP_ADMIN_EMAIL=admin@demo.local
BOOTSTRAP_ADMIN_PASSWORD=demo12345
BOOTSTRAP_ADMIN_NAME=Demo Admin

# --- Heatmap watchdog ---
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_SECONDS=1800
